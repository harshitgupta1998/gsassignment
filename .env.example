## Example .env for GSAssignment
## Copy this file to .env and fill in any secrets/overrides you need.
# Keep your real .env out of version control (add .env to .gitignore).

# OpenAI API key (required for --mode llm)
OPENAI_API_KEY="sk-REPLACE_ME"
# Optional: override model to use when calling the OpenAI API
OPENAI_MODEL="gpt-4o-mini"
